SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your-redis-token
UPSTASH_QSTASH_TOKEN=your-qstash-token
UPSTASH_QSTASH_URL=https://qstash.upstash.io/v2/publish/

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=llama3.1:8b
OLLAMA_REPLY_MODEL=mistral:7b
OLLAMA_FAST_MODEL=phi3:mini

# AI Provider: "ollama" | "groq"
AI_PROVIDER=ollama
GROQ_API_KEY=your-groq-api-key

POLLINATIONS_API_URL=https://image.pollinations.ai/prompt/

META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=byaper_webhook_verify_token

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GBP_API_KEY=your-gbp-api-key

# true = no real API calls, use mock data
SIMULATION_MODE=true

APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
ENVIRONMENT=development

SENTRY_DSN=
